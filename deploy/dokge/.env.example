# ============================================================
# ysk-asan 개발용 MariaDB 환경 변수 (Dockge 스택)
# ------------------------------------------------------------
# 사용법:  cp .env.example .env   후 실제 값으로 변경
# .env 는 .gitignore 처리되어 git 에 올라가지 않습니다.
# !! .env.example 에는 절대 실제 비밀번호를 적지 마세요 (예시 값만).
# ============================================================

# MariaDB 관리자(root) 비밀번호
MARIADB_ROOT_PASSWORD=change-this-strong-root-pw

# 애플리케이션이 사용할 DB 이름 / 계정
MARIADB_DATABASE=ysk_asan
MARIADB_USER=ysk
MARIADB_PASSWORD=change-this-strong-user-pw

# 호스트에 노출할 DB 포트 (로컬에서 이 포트로 접속)
MARIADB_PORT=3306