# ============================================================
# ysk-asan 개발용 MariaDB 환경 변수 (Dockge 스택)
# ------------------------------------------------------------
# 사용법:  cp .env.example .env   후 실제 값으로 변경
# .env 는 .gitignore 처리되어 git 에 올라가지 않습니다.
# !! .env.example 에는 절대 실제 비밀번호를 적지 마세요 (예시 값만).
# ============================================================

# MariaDB 관리자(root) 비밀번호
MARIADB_ROOT_PASSWORD=change-this-strong-root-pw

# 애플리케이션이 사용할 DB 이름 / 계정
MARIADB_DATABASE=ysk_asan
MARIADB_USER=ysk
MARIADB_PASSWORD=change-this-strong-user-pw

# 호스트에 노출할 DB 포트 (로컬에서 이 포트로 접속)
MARIADB_PORT=3306

# ── 운영 app (compose.prod.yaml 전용) ──
# WAS(애플리케이션) 호스트 노출 포트
WAS_PORT=8181
# 최초 배포 1회만 update(빈 스키마에 contact/users 테이블 생성).
# 이후 배포부터는 아래 줄을 주석/삭제해 기본값(validate)으로 운영하세요.
# DB_DDL_AUTO=update

# 로그인 유지(Remember-Me) 토큰 서명 키 — 반드시 강한 랜덤값으로 변경하세요.
#   예) openssl rand -base64 48
# 노출 시 토큰 위조가 가능하므로 절대 공개 금지. 변경 시 기존 로그인 유지 쿠키는 모두 무효화됩니다.
REMEMBER_ME_KEY=change-this-to-a-long-random-secret